<?xml version="1.0" ?>
<!--
  Composite pick scene for the SO-101 5+1 DOF arm (LeRobot/SO-ARM100 hardware).

  Layout strategy:
    - Arm base sits at world origin (per upstream URDF). The cube and table
      positions are tuned around there.
    - Cube rest position: (0.30, 0.0, 0.04) — on the floor in front of the
      base, within the gripper's reach envelope.
    - Target zone: (0.30, 0.40, 0.02).
    - Cameras frame the cube/target area.

  This file is the single MJCF entry point; urdf/so101_official/so101_new_calib.xml
  provides the arm, and we add cube/table/cameras/lights here, all sharing
  one worldbody.
-->
<mujoco model="so101_pick_scene">
  <compiler angle="radian" meshdir="so101_official/assets" autolimits="true"/>

  <option timestep="0.005" iterations="50" solver="Newton" integrator="Euler" cone="pyramidal"/>

  <visual>
    <global offheight="1024" offwidth="1024"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
  </visual>

  <default>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
    <!-- Override the upstream damping/friction for MJX-friendly numericals. -->
    <joint damping="1.5" armature="0.3" frictionloss="0.1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.5 0.7" rgb2="0.1 0.15 0.2"
             width="512" height="512"/>
    <texture name="texplane" type="2d" builtin="checker" rgb1="0.3 0.3 0.4"
             rgb2="0.4 0.4 0.5" width="512" height="512" mark="cross" markrgb="0.8 0.8 0.9"/>
    <material name="matplane" reflectance="0.4" texture="texplane" texrepeat="3 3"
              texuniform="true" rgba="0.7 0.7 0.8 1"/>
    <material name="mat_white" rgba="0.95 0.95 0.95 1" specular="0.4" shininess="0.6"/>
    <material name="mat_gray" rgba="0.55 0.55 0.6 1" specular="0.6" shininess="0.8"/>
    <material name="mat_dark" rgba="0.18 0.18 0.22 1" specular="0.3" shininess="0.4"/>
    <material name="mat_table" rgba="0.85 0.78 0.65 1" specular="0.2" shininess="0.4"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse=".9 .9 .9" specular=".3 .3 .3" pos="0 0 5" dir="0 0 -1"/>
    <light directional="true" diffuse=".5 .5 .5" specular="0 0 0" pos="2 -2 3" dir="-0.5 0.5 -1"/>

    <geom name="floor" pos="0 0 0" size="1 1 0.05" type="plane" material="matplane" condim="3"/>

    <!-- Table behind the cube so the workspace has visual depth without
         interfering with the arm's reach envelope. -->
    <geom name="table" pos="0.0 0.25 0.0" size="0.35 0.10 0.02" type="box"
          material="mat_table" condim="3"/>

    <!-- Low pedestal to raise ball into the arm's comfortable reach envelope. -->
    <geom name="pedestal" pos="0.30 0.0 0.02" size="0.025 0.025 0.02" type="box"
          rgba="0.6 0.6 0.65 1" condim="3"/>

    <!-- 25 mm-diameter red ball (body named "cube" for backward compat). -->
    <body name="cube" pos="0.30 0.0 0.065">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="sphere" size="0.0125"
            rgba="0.85 0.05 0.05 1" mass="0.05" condim="4"
            solref="0.02 1.0" solimp="0.9 0.95 0.001 0.5 2"/>
    </body>

    <!-- Push target zone: thin blue disc/box (MJX can't collide with cylinders).
         Solid saturated blue + a near-white inner ring so it pops visually. -->
    <body name="target_zone" pos="0.30 0.40 0.021">
      <geom name="target_zone_disc" type="box" size="0.06 0.06 0.002"
            rgba="0.1 0.3 0.95 1" contype="0" conaffinity="0"/>
      <geom name="target_zone_inner" type="box" size="0.025 0.025 0.003"
            rgba="0.95 0.95 1.0 1" pos="0 0 0.0005" contype="0" conaffinity="0"/>
    </body>

    <!-- Cameras, positioned to frame the new workspace center (~0.30, 0.20, 0.04).
         Same camera names as the old scene; xyaxes will need re-derivation later
         if critical, but visually they're fine for boot-time smoke checks. -->
    <camera name="over_shoulder" pos="-0.05 0.55 0.50" xyaxes="-0.74 -0.67 0 0.22 -0.24 0.95"
            mode="fixed" fovy="48"/>
    <camera name="pov" pos="0.40 -0.30 0.65" xyaxes="0.93 -0.37 0 0.21 0.51 0.84"
            mode="fixed" fovy="55"/>
    <camera name="front_top" pos="0.30 0.0 0.80" xyaxes="0 -1 0 0.94 0 0.34"
            mode="fixed" fovy="42"/>
    <!--
      WRIST (EYE-IN-HAND) CAMERA
      ===========================
      This camera CANNOT be declared here because it must be a child element
      of the arm's end-effector body ("Fixed_Jaw" in so101_new_calib.xml) so
      that MuJoCo parents its pose to the gripper rather than the world frame.

      MJCF <include> tags do not allow the parent file to inject children into
      a body defined inside the included file.  Two options:

        Option A — preferred: use the MjSpec Python API (_build_composite_spec
          in so101_mjx.py), which calls spec.find("body","Fixed_Jaw") and then
          ee_body.add_camera(...).  The Python path already does this correctly.

        Option B — embed directly: add the following block inside the
          <body name="Fixed_Jaw"> element in so101_official/so101_new_calib.xml:

            <camera name="wrist"
                    pos="0 -0.02 0.04"
                    xyaxes="1 0 0  0 0 1"
                    fovy="60"/>

      A static world-frame wrist camera (the old entry) is purposely omitted
      here because it produced a view that never tracked the arm's pose.
    -->
    <camera name="portfolio" pos="-0.2 -1.0 0.85" xyaxes="0.83 -0.56 0 0.18 0.28 0.94"
            mode="fixed" fovy="36"/>

    <!-- Workspace origin marker on the floor. -->
    <site name="workspace_origin" pos="0.30 0.20 0.04" size="0.01" rgba="0 1 0 0.5"/>

    <!-- Arm inclusion. The SO-101 URDF root body "base" sits at world origin,
         so the arm physically occupies space around (0, 0, 0) and reaches
         forward toward +x and +y. -->
    <include file="so101_official/so101_new_calib.xml"/>
  </worldbody>

  <!-- Re-override the upstream position motors with smaller gains so the SO-101
       PD-style position actuators (kp=50 default) don't saturate under a 0..1
       ctrl signal. We map every arm revolute + the gripper into a single
       ctrl vector of length 6, matching the new action dim. -->
  <actuator>
    <motor name="shoulder_pan_motor" joint="shoulder_pan" gear="60" ctrlrange="-1 1"/>
    <motor name="shoulder_lift_motor" joint="shoulder_lift" gear="60" ctrlrange="-1 1"/>
    <motor name="elbow_flex_motor" joint="elbow_flex" gear="40" ctrlrange="-1 1"/>
    <motor name="wrist_flex_motor" joint="wrist_flex" gear="20" ctrlrange="-1 1"/>
    <motor name="wrist_roll_motor" joint="wrist_roll" gear="20" ctrlrange="-1 1"/>
    <motor name="gripper_motor" joint="gripper" gear="20" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
