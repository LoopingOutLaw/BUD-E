<?xml version="1.0" ?>
<!--
  Composite pick scene for the SO-101 5+1 DOF arm (LeRobot/SO-ARM100 hardware).

  Layout strategy:
    - Arm base sits at world origin (per upstream URDF). The cube and table
      positions are tuned around there.
    - Cube rest position: (0.30, 0.0, 0.01) — on the floor in front of the
      base, within the gripper's reach envelope. 20mm cube, half-extent 0.010.
    - Target zone: (0.32, 0.16, 0.021).
    - Cameras frame the cube/target area.

  This file is the single MJCF entry point; urdf/so101_official/so101_new_calib.xml
  provides the arm, and we add cube/table/cameras/lights here, all sharing
  one worldbody.
-->
<mujoco model="so101_pick_scene">
  <compiler angle="radian" meshdir="so101_official/assets" autolimits="true"/>

  <option timestep="0.002" iterations="100" ls_iterations="50"
          solver="Newton" integrator="Euler" cone="pyramidal"/>

  <visual>
    <global offheight="1024" offwidth="1024"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
  </visual>

  <default>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
    <joint damping="1.5" armature="0.3" frictionloss="0.1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.5 0.7" rgb2="0.1 0.15 0.2"
             width="512" height="512"/>
    <texture name="texplane" type="2d" builtin="checker" rgb1="0.3 0.3 0.4"
             rgb2="0.4 0.4 0.5" width="512" height="512" mark="cross" markrgb="0.8 0.8 0.9"/>
    <material name="matplane" reflectance="0.4" texture="texplane" texrepeat="3 3"
              texuniform="true" rgba="0.7 0.7 0.8 1"/>
    <material name="mat_white" rgba="0.95 0.95 0.95 1" specular="0.4" shininess="0.6"/>
    <material name="mat_gray" rgba="0.55 0.55 0.6 1" specular="0.6" shininess="0.8"/>
    <material name="mat_dark" rgba="0.18 0.18 0.22 1" specular="0.3" shininess="0.4"/>
    <material name="mat_table" rgba="0.85 0.78 0.65 1" specular="0.2" shininess="0.4"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse=".9 .9 .9" specular=".3 .3 .3" pos="0 0 5" dir="0 0 -1"/>
    <light directional="true" diffuse=".5 .5 .5" specular="0 0 0" pos="2 -2 3" dir="-0.5 0.5 -1"/>
    <light directional="true" diffuse=".3 .3 .3" specular="0 0 0" pos="-1 1 2" dir="0.3 -0.3 -1"/>

    <geom name="floor" pos="0 0 0" size="1 1 0.05" type="plane" material="matplane"
          condim="3" friction="1.0 0.005 0.0001"/>

    <geom name="table" pos="0.0 0.25 0.0" size="0.35 0.10 0.02" type="box"
          material="mat_table" condim="3"/>

    <!-- 20 mm cube (half-extent 0.010). Heavy, high-friction for stable grasp.
         friction="5 0.5 0.1": very high sliding friction to prevent slip.
         solref/solimp: stiff contact to prevent interpenetration.
         condim=6: full contact (sliding + torsional friction). -->
    <body name="cube" pos="0.30 0.0 0.010">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="box" size="0.010 0.010 0.010"
            rgba="0.85 0.05 0.05 1" mass="0.30" condim="6"
            friction="5.0 0.5 0.1"
            solref="0.01 1.0" solimp="0.95 0.99 0.001 0.5 2"/>
    </body>

    <!-- Target zone: blue disc + white inner ring. -->
    <body name="target_zone" pos="0.32 0.16 0.021">
      <geom name="target_zone_disc" type="box" size="0.06 0.06 0.002"
            rgba="0.1 0.3 0.95 1" contype="0" conaffinity="0"/>
      <geom name="target_zone_inner" type="box" size="0.025 0.025 0.003"
            rgba="0.95 0.95 1.0 1" pos="0 0 0.0005" contype="0" conaffinity="0"/>
    </body>

    <!-- Bowl at target to catch the dropped cube. -->
    <body name="bowl" pos="0.32 0.16 0.016">
      <geom name="bowl_floor" type="cylinder" size="0.028 0.001"
            rgba="0.30 0.30 0.36 1" contype="4" conaffinity="2" condim="3"/>
    </body>

    <!-- Cameras -->
    <camera name="over_shoulder" pos="-0.05 0.55 0.50" xyaxes="-0.74 -0.67 0 0.22 -0.24 0.95"
            mode="fixed" fovy="48"/>
    <camera name="pov" pos="0.40 -0.30 0.65" xyaxes="0.93 -0.37 0 0.21 0.51 0.84"
            mode="fixed" fovy="55"/>
    <camera name="front_top" pos="0.30 0.0 0.80" xyaxes="0 -1 0 0.94 0 0.34"
            mode="fixed" fovy="42"/>
    <camera name="portfolio" pos="-0.2 -1.0 0.85" xyaxes="0.83 -0.56 0 0.18 0.28 0.94"
            mode="fixed" fovy="36"/>

    <site name="workspace_origin" pos="0.30 0.20 0.04" size="0.01" rgba="0 1 0 0.5"/>

    <!-- Arm inclusion -->
    <include file="so101_official/so101_new_calib.xml"/>
  </worldbody>

  <actuator>
    <motor name="shoulder_pan_motor" joint="shoulder_pan" gear="60" ctrlrange="-1 1"/>
    <motor name="shoulder_lift_motor" joint="shoulder_lift" gear="60" ctrlrange="-1 1"/>
    <motor name="elbow_flex_motor" joint="elbow_flex" gear="40" ctrlrange="-1 1"/>
    <motor name="wrist_flex_motor" joint="wrist_flex" gear="20" ctrlrange="-1 1"/>
    <motor name="wrist_roll_motor" joint="wrist_roll" gear="20" ctrlrange="-1 1"/>
    <motor name="gripper_motor" joint="gripper" gear="20" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
